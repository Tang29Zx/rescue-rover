#!/bin/sh

set -eu

protected_branch='main'
protected_ref="refs/heads/$protected_branch"
protected_update=0
protected_delete=0
malformed_input=0

# Git supplies every pending ref update on standard input. Read the complete
# stream before deciding whether an interactive confirmation is required.
while IFS=' ' read -r local_ref local_oid remote_ref remote_oid; do
    if [ -z "$local_ref" ] || [ -z "$local_oid" ] || \
       [ -z "$remote_ref" ] || [ -z "$remote_oid" ]; then
        malformed_input=1
        continue
    fi

    if [ "$remote_ref" != "$protected_ref" ]; then
        continue
    fi

    case "$local_oid" in
        ''|*[!0]*) protected_update=1 ;;
        *) protected_delete=1 ;;
    esac
done

if [ "$malformed_input" -eq 1 ]; then
    printf '%s\n' 'ERROR: Git supplied malformed pre-push reference data.' >&2
    exit 1
fi

if [ "$protected_delete" -eq 1 ]; then
    printf '%s\n' \
        "ERROR: Deleting protected branch '$protected_branch' is not allowed." \
        'Create or update the branch through an administrator-reviewed recovery process.' >&2
    exit 1
fi

if [ "$protected_update" -eq 0 ]; then
    exit 0
fi

if [ "${ALLOW_PROTECTED_BRANCH_PUSH-}" = '1' ]; then
    printf '%s\n' \
        '================================================================' \
        "WARNING: Local protection for '$protected_branch' was explicitly bypassed." \
        'ALLOW_PROTECTED_BRANCH_PUSH=1 is set for this push.' \
        '================================================================' >&2
    exit 0
fi

printf '%s\n' \
    '================================================================' \
    "WARNING: You are pushing directly to protected branch '$protected_branch'." \
    'GitHub may allow this when Repository admin has Always bypass.' \
    'Normal feature changes should use a branch and pull request.' \
    '================================================================' >&2

if ! ( : </dev/tty ) 2>/dev/null; then
    printf '%s\n' \
        'Direct pushes to the protected branch require an interactive terminal.' \
        'Push rejected.' >&2
    exit 1
fi

exec 3<>/dev/tty
required_confirmation="PUSH $protected_branch"
printf "Type '%s' to continue: " "$required_confirmation" >&3

if ! IFS= read -r confirmation <&3; then
    exec 3>&-
    printf '\n%s\n' 'Push rejected: confirmation was not received.' >&2
    exit 1
fi
exec 3>&-

if [ "$confirmation" != "$required_confirmation" ]; then
    printf '%s\n' \
        "Push rejected: confirmation must exactly match '$required_confirmation'." >&2
    exit 1
fi

printf '%s\n' "Confirmed direct push to '$protected_branch'." >&2
